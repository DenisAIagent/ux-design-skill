{
  "ok": true,
  "taskCredits": 1,
  "caption": [
    {
      "start_time": "00:00:00.000",
      "end_time": "00:00:01.840",
      "text": "Les devs ne peuvent pas compenser 1 mauvais design."
    },
    {
      "start_time": "00:00:01.960",
      "end_time": "00:00:03.760",
      "text": "Et pour ça je te propose 1 test simple,"
    },
    {
      "start_time": "00:00:03.840",
      "end_time": "00:00:04.840",
      "text": "donne ton produit à quelqu'un,"
    },
    {
      "start_time": "00:00:05.040",
      "end_time": "00:00:07.360",
      "text": "demande-lui de faire 1 action-clé et ne dis plus rien."
    },
    {
      "start_time": "00:00:07.480",
      "end_time": "00:00:09.120",
      "text": "S'il te pose 1 question sur le comment,"
    },
    {
      "start_time": "00:00:09.160",
      "end_time": "00:00:12.080",
      "text": "ce n'est pas 1 problème de dev mais 1 problème d'interface."
    },
    {
      "start_time": "00:00:12.200",
      "end_time": "00:00:15.040",
      "text": "Parce que oui les devs peuvent optimiser la vitesse, la performance,"
    },
    {
      "start_time": "00:00:15.200",
      "end_time": "00:00:16.840",
      "text": "la stabilité, la sécurité,"
    },
    {
      "start_time": "00:00:17.280",
      "end_time": "00:00:18.240",
      "text": "tout l'aspect technique."
    },
    {
      "start_time": "00:00:18.280",
      "end_time": "00:00:21.120",
      "text": "Mais ça suffit de remettre la faute sur eux Quand l'app n'est pas intuitive."
    },
    {
      "start_time": "00:00:21.200",
      "end_time": "00:00:24.200",
      "text": "ils ne peuvent pas décider à la place de l'utilisateur ou cliquer ni par où"
    },
    {
      "start_time": "00:00:24.440",
      "end_time": "00:00:26.120",
      "text": "commencer. Et si ton produit n'est pas intuitif,"
    },
    {
      "start_time": "00:00:26.200",
      "end_time": "00:00:28.360",
      "text": "le problème n'est pas technique, mais il est UX."
    },
    {
      "start_time": "00:00:28.560",
      "end_time": "00:00:29.520",
      "text": "Donc pour remédier à ça,"
    },
    {
      "start_time": "00:00:29.521",
      "end_time": "00:00:32.440",
      "text": "je te propose 1 audit en visio et tu trouveras le lien dans la bio."
    }
  ]
}